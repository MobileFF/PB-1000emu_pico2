1000 REM ============================================================
1010 REM  BANK2/3 RAM Test2 + Test3  (BASIC PROGRAM)
1020 REM
1030 REM  PREREQ: ram_test.py MUST BE PLACED IN /ext/
1040 REM
1050 REM  Test2: WRITE 0..255 TO &H8000-&H80FF AND VERIFY
1060 REM  Test3: WRITE 255..0 TO &HFF00-&HFFFF AND VERIFY
1070 REM
1080 REM  BANK SWITCH HOOKS:
1090 REM    CALL &H5E41  UA bit[5:4]=10  -> ROUTE TO BANK2
1100 REM    CALL &H5E51  UA bit[5:4]=11  -> ROUTE TO BANK3
1110 REM    CALL &H5E61  UA bit[5:4]=00  -> RESTORE
1120 REM ============================================================
1130 REM --- BANK2 ---
1140 CALL &H5E41
1150 REM TEST2: HEAD-256 SEQUENTIAL
1160 FOR I=0 TO 255
1170 POKE &H8000+I,I
1180 NEXT I
1190 E=0
1200 FOR I=0 TO 255
1210 IF PEEK(&H8000+I)<>I THEN E=E+1
1220 NEXT I
1230 IF E=0 THEN PRINT "B2 T2 OK" ELSE PRINT "B2 T2 NG:";E
1240 REM TEST3: TAIL-256 REVERSE
1250 FOR I=0 TO 255
1260 POKE &HFF00+I,255-I
1270 NEXT I
1280 E=0
1290 FOR I=0 TO 255
1300 IF PEEK(&HFF00+I)<>255-I THEN E=E+1
1310 NEXT I
1320 IF E=0 THEN PRINT "B2 T3 OK" ELSE PRINT "B2 T3 NG:";E
1330 CALL &H5E61
1340 REM --- BANK3 ---
1350 CALL &H5E51
1360 REM TEST2: HEAD-256 SEQUENTIAL
1370 FOR I=0 TO 255
1380 POKE &H8000+I,I
1390 NEXT I
1400 E=0
1410 FOR I=0 TO 255
1420 IF PEEK(&H8000+I)<>I THEN E=E+1
1430 NEXT I
1440 IF E=0 THEN PRINT "B3 T2 OK" ELSE PRINT "B3 T2 NG:";E
1450 REM TEST3: TAIL-256 REVERSE
1460 FOR I=0 TO 255
1470 POKE &HFF00+I,255-I
1480 NEXT I
1490 E=0
1500 FOR I=0 TO 255
1510 IF PEEK(&HFF00+I)<>255-I THEN E=E+1
1520 NEXT I
1530 IF E=0 THEN PRINT "B3 T3 OK" ELSE PRINT "B3 T3 NG:";E
1540 CALL &H5E61
1550 PRINT "DONE"
